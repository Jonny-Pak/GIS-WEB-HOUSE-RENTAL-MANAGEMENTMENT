# Django
SECRET_KEY=replace-me
DEBUG=1

# Database configuration
# For quick local testing, use SQLite (set DB_BACKEND=sqlite3)
# For production, use PostgreSQL (set DB_BACKEND=postgresql)
DB_BACKEND=postgresql
DB_NAME=quanlythuenha
DB_USER=postgres
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=5432

# Email Configuration - OTP Sending
# Choose ONE of the following options below:

# Option 1: Gmail SMTP (Recommended for OTP testing)
# - Go to myaccount.google.com/apppasswords
# - Generate an App Password (not regular password)
# - Copy the 16-character password as EMAIL_HOST_PASSWORD
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0

# Option 2: Mailtrap SMTP (if you have account)
# Uncomment and fill these instead of Option 1
# EMAIL_HOST=live.smtp.mailtrap.io
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-mailtrap-username
# EMAIL_HOST_PASSWORD=your-mailtrap-password
# EMAIL_USE_TLS=1
# EMAIL_USE_SSL=0
# DEFAULT_FROM_EMAIL=hello@demomailtrap.co

# Note: Mailtrap API mode is not recommended for OTP (demo restriction)
# MAILTRAP_API_TOKEN=your-mailtrap-api-token

# Support Configuration
SUPPORT_INBOX_EMAIL=thuenhanhanh.gis@gmail.com
SUPPORT_CONTACT_PHONE=0900 123 456
